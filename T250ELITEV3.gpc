int ModEdit;   
int display_EDIT;   
int EntireScript_OnOff = TRUE;
int show_mesage_time; 
int count_black;
int gameplay_idle_time;
int startup_splash_active;
int startup_splash_stage;
int startup_splash_time;
int menu_back_lock;
