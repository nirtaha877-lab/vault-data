combo EliteBhop{ set_val(JUMP_BTN, 100); wait(40); set_val(JUMP_BTN, 0); wait(80); set_val(JUMP_BTN, 100); wait(40); set_val(JUMP_BTN, 0); wait(80); }

define DoubleTapMarkBtn = FALSE;
define SPOT_BTN = PS4_R1;
int AlwaysON_ASpot = TRUE;
int KS_auto_spot   = TRUE;

combo EliteSpot_cmb { set_val(SPOT_BTN, 100); wait(40); wait(40); if(DoubleTapMarkBtn) set_val(SPOT_BTN, 100); wait(40); set_val(SPOT_BTN, 0); wait(960); }
combo EliteReload_cmb { set_val(PS4_UP,100); wait(100); }

function Elite_Offset(Stick,Value) {
    set_val(Stick, clamp(Value * (100 - abs(get_val(Stick))) / 100 + get_val(Stick), -100, 100));
    return;
}

function EmitEliteOutput(stick, value) {
    set_val(stick, clamp(((value / 328) * (100 - abs(get_val(stick))) / 100) + get_val(stick), -100, 100));
}

function Smooth_Tracking_Elite(step_x, step_y) {
    track_smooth_x = (track_smooth_x * 4 + step_x) / 5;
    track_smooth_y = (track_smooth_y * 4 + step_y) / 5;
    Elite_Offset(XB1_RX, track_smooth_x);
    Elite_Offset(XB1_RY, track_smooth_y);
}

combo EliteAA_Combo {
    EliteAimAdjust(RX,  EliteTrack_Strength);
    wait(EliteTrack_Delay);
    EliteAimAdjust(RY,  EliteTrack_Strength);
    wait(EliteTrack_Delay);
    EliteAimAdjust(RX, -EliteTrack_Strength);
    wait(EliteTrack_Delay);
    EliteAimAdjust(RY, -EliteTrack_Strength);
    wait(EliteTrack_Delay);
}

function EliteAimAdjust(Axis, Strength) {
    if(abs(get_ival(Axis)) >= 8) set_val(Axis, get_val(Axis) + (Strength * Elite_AA_Intensity) / 3);
}

function ResetEliteTrackState() { track_smooth_x = 0; track_smooth_y = 0; }

function FixStickDrift() {
    if(get_val(XB1_LX) == get_ival(XB1_LX) && get_val(XB1_LY) == get_ival(XB1_LY) && isqrt(pow(abs(get_ival(XB1_LX)),2) + pow(abs(get_ival(XB1_LY)),2)) <= DeadZone) {
        set_val(XB1_LX,0); set_val(XB1_LY,0);
    }
    if(get_val(XB1_RX) == get_ival(XB1_RX) && get_val(XB1_RY) == get_ival(XB1_RY) && isqrt(pow(abs(get_ival(XB1_RX)),2) + pow(abs(get_ival(XB1_RY)),2)) <= DeadZone) {
        set_val(XB1_RX,0); set_val(XB1_RY,0);
    }
}

int KS_anti_recoil = TRUE;  
function ApplyEliteRecoil() {
    if(!EliteRecoil_Active || !get_ival(FIRE_BTN)) return;
    
    if(abs(get_val(RX)) < abs(EliteRecoil_H) + 10) EmitEliteOutput(RX, EliteRecoil_H * 327);
    if(abs(get_val(RY)) < EliteRecoil_V + 10) EmitEliteOutput(RY, EliteRecoil_V * 327);
}

combo Elite_FireAimBoost {
    Elite_Offset(LX, (AimFireBoost * 7)); Elite_Offset(LY, (AimFireBoost * 2)); wait(40);
    Elite_Offset(LX, (AimFireBoost * -7)); Elite_Offset(LY, (AimFireBoost * -2)); wait(40);
    Elite_Offset(LX, (AimFireBoost * 7)); Elite_Offset(LY, (AimFireBoost * -2)); wait(40);
    Elite_Offset(LX, (AimFireBoost * -7)); Elite_Offset(LY, (AimFireBoost * 2)); wait(40);
}

combo EliteYY_cmb { set_val(SWITCHWEAPON_BTN, 100); wait(40); set_val(SWITCHWEAPON_BTN, 0); wait(clamp(YY_Delay_Timing, 20, 100)); set_val(SWITCHWEAPON_BTN, 100); wait(35); set_val(SWITCHWEAPON_BTN, 0); wait(20); }
           
combo EliteTracking { Smooth_Tracking_Elite((track_dynamic_strength * 10) / 10, 0); wait(EliteTrack_Delay + 2); Smooth_Tracking_Elite((track_dynamic_strength * -10) / 10, 0); wait(EliteTrack_Delay + 2); }

function on_the_fly_display (f_string, f_print, f_val){
    cls_oled(0);  
    draw_rectangle();
    print(f_string, 20, OLED_FONT_MEDIUM, OLED_WHITE, f_print);  
    number_to_string(f_val, find_digits(f_val));
    time_to_clear_screen  = 2000;
}      
       
