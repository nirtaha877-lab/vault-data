    set_pvar(SPVAR_9,StickDrift_Fix); 
    set_pvar(SPVAR_16,StickyAim_Active);
    set_pvar(SPVAR_17,BlockRumble_Active);
    set_pvar(SPVAR_19,AimFireBoost_Active);
    set_pvar(SPVAR_18,YY_Movement_Active);
