}
                      
combo MESSAGE { wait(20); exit_wait = 2000; save_toggles (); cls_oled(0); print(horizontal_center_offset(sizeof(EXIT_TXT1), OLED_FONT_MEDIUM ), 2, OLED_FONT_MEDIUM, 1, EXIT_TXT1[0]); print(horizontal_center_offset(sizeof(EXIT_TXT2), OLED_FONT_MEDIUM ), 23, OLED_FONT_MEDIUM, 1, EXIT_TXT2[0]); }                        
function blinck ( var){ if(var) BlinckColor = Green; else BlinckColor = Red; combo_run(BLINK_NOTIFY); }                           
combo BLINK_NOTIFY { colourled(BlinckColor); wait(300); colourled(ColorOFF); wait(100); colourled(BlinckColor); wait(300); colourled(ColorOFF); }                                
int blink_n ;
combo Blink_MOD_ON   { colourled(ColorOFF); wait(500); colourled(ColorOFF); wait(1000); blink_n +=1; if( blink_n > 0)blink_n = 1; }                                
                                
const uint8 FONT_STATS[][] = { { 7, 10, 18 }, { 11, 18, 11 }, { 16, 26, 7 } };                              
function display_edit(f_val) { print(center_x(sizeof(EditVarStr[adjust_variable_idx])-1, OLED_FONT_SMALL_WIDTH), 16, OLED_FONT_SMALL, OLED_WHITE, EditVarStr[adjust_variable_idx]); number_to_string(f_val, find_digits(f_val)); }       
function f_go_forward (f_variable) { f_variable +=1; if(f_variable > Min_Max_Options[modName_idx][1] )f_variable = Min_Max_Options[modName_idx][0]; need_to_be_save = TRUE; blinck( f_variable ); return f_variable; }
function f_go_back (f_variable) { f_variable -=1; if(f_variable < Min_Max_Options[modName_idx][0] )f_variable = Min_Max_Options[modName_idx][1]; need_to_be_save = TRUE; blinck( f_variable ); return f_variable; }

int ssss, c_c_c,c_val;   
function number_to_string(f_val,f_digits) {                  
    ssss = 1;  c_val = 10000;                            
    if(f_val < 0) { putc_oled(ssss,45); ssss += 1; f_val = abs(f_val); }                                                 
    for(c_c_c = 5; c_c_c >= 1; c_c_c--) {                                                 
        if(f_digits >= c_c_c) {                                             
            putc_oled(ssss,ASCII_NUM[f_val / c_val]);    
            f_val = f_val % c_val; ssss +=  1;                                  
            if(c_c_c == 4) { putc_oled(ssss,44); ssss += 1; }                                        
        }                                             
        c_val /= 10;                                  
    }                                                
    puts_oled(center_x(ssss - 1,OLED_FONT_MEDIUM_WIDTH),28,OLED_FONT_MEDIUM,ssss - 1,OLED_WHITE); 
}                                                     

int n_str_;                  
function print_number(f_val,f_digits ,print_s_x , print_s_y , f_font, f_color) {                                                      
    n_str_ = 1;  c_val = 10000;                       
    if(f_val < 0) { putc_oled(n_str_,45); n_str_ += 1; f_val = abs(f_val); }                                                                                               
    for(c_c_c = 5; c_c_c >= 1; c_c_c--) {                                                 
        if(f_digits >= c_c_c) { putc_oled(n_str_,ASCII_NUM[f_val / c_val]); f_val = f_val % c_val; n_str_ +=  1; }                                             
        c_val /= 10;                                  
    }                                                 
    puts_oled(print_s_x,print_s_y,f_font,n_str_ - 1,f_color);
}                                       
                                                      
int f_min, f_max;
define Y_Arrow = 36;
const string EDIT_VALUE_TXT = "Hold LT/L2 +"; 

function edit_val( f_val) {
    draw_rectangle();
    print( center_x(sizeof(EDIT_VALUE_TXT)-1, OLED_FONT_SMALL_WIDTH), 53, OLED_FONT_SMALL, 0, EDIT_VALUE_TXT[0] ); 

    putc_oled(1,LEFT_arrow); puts_oled(20, 28, OLED_FONT_SMALL, 1, 1);     
    putc_oled(1,RIGHT_arrow); puts_oled(100, 28, OLED_FONT_SMALL, 1, 1);
    
    f_min = ValRange[adjust_variable_idx][0];                          
    f_max = ValRange[adjust_variable_idx][1];  
    
    print_number(f_min ,find_digits(f_min) ,5 , 28 , OLED_FONT_SMALL, 1); 
    print_number(f_max ,find_digits(f_max) ,110 , 28 , OLED_FONT_SMALL, 1);
                                          
    if(get_ival(ADS_BTN)){                  
        if(press_hold(XB1_RIGHT)){ f_val ++; if(f_val > f_max ) f_val = f_max; display_EDIT = TRUE; need_to_be_save = TRUE; }                                     
        if(press_hold(XB1_LEFT)){ f_val --; if(f_val < f_min ) f_val = f_min; display_EDIT = TRUE; need_to_be_save = TRUE; }                                     
        if(press_hold(XB1_UP)){ f_val +=10; if(f_val > f_max ) f_val = f_max; display_EDIT = TRUE; need_to_be_save = TRUE; }                                     
        if(press_hold(XB1_DOWN)){ f_val -=10; if(f_val < f_min ) f_val = f_min; display_EDIT = TRUE; need_to_be_save = TRUE; }                                     
    }                                      
    return f_val;                        
}    
                                             
function press_hold(f_btn) { return event_press(f_btn) || get_ival(f_btn) && get_ptime(f_btn) > 250 && get_ptime(f_btn) % (get_rtime() * 8) == 0; }               
function find_digits(f_num) { f_num = abs(f_num); if(f_num / 10000 > 0) return 5; if(f_num / 1000 > 0) return 4; if(f_num / 100 > 0) return 3; if(f_num / 10 > 0) return 2; return 1; }                                                     
function center_x(f_chars,f_font) { return (OLED_WIDTH / 2) - ((f_chars * f_font) / 2); }                                                      
function draw_rectangle() { 
    rect_oled(0, 0, 128, 14, 1, 1); 
    print(center_x(sizeof(MENU_TOP_TITLE) - 1, OLED_FONT_SMALL_WIDTH), 3, OLED_FONT_SMALL, 0, MENU_TOP_TITLE[0]);
    rect_oled(0, 50, 128, 14, 1, 1);
}

const string ModOption_7_0 = "Disable"; const string ModOption_7_1 = "Like CoD"; const string ModOption_7_2 = "Like PUBG"; 
const string ModOption_55_0 = "Disable"; const string ModOption_55_1 = "Fire Only"; const string ModOption_55_2 = "ADS Only"; const string ModOption_55_3 = "On Fire"; const string ModOption_55_4 = "Always On"; 
define ShotModOptions = 31;
const string ModOption_31_0 = "Disable"; const string ModOption_31_1 = "Fire Only"; const string ModOption_31_2 = "ADS & Fire"; const string ModOption_31_3 = "ADS Only"; 

const string ModOption_50_0 = "Default"; 
const string ModOption_50_1 = "8 ms"; 
const string ModOption_50_2 = "6 ms"; 
const string ModOption_50_3 = "4 ms"; 
const string ModOption_50_4 = "2 ms"; 
const string ModOption_50_5 = "1 ms"; 

define UP_arrow = 131; define DOWN_arrow = 132; define LEFT_arrow = 133; define RIGHT_arrow = 134; define TRIANGLE_txt = 130; define Y_txt = 89; define CROSS_txt = 127; define A_txt = 65;
int col_char_left = OLED_WHITE; int col_char_right = OLED_WHITE; int col_rec_left = 1; int col_rec_right = 1;
define SINGLE = 28;
const string NO_EDIT_VARIABLE =" No Edit Variable"; const string PRESS_A_TO_EDIT =" A/CROSS to Edit "; const string MOD_LABEL ="MOD:"; const string SLOT_LABEL ="MSL:";
int slot_numb ;

function display_mod( f_string, mod_name, f_toggle, f_option) {   
    print(f_string, 18, OLED_FONT_SMALL, OLED_WHITE, mod_name); 
    
    putc_oled(1,LEFT_arrow); puts_oled(10, 53, OLED_FONT_SMALL, 1, 0);     
    putc_oled(1,RIGHT_arrow); puts_oled(110, 53, OLED_FONT_SMALL, 1, 0);
    
    print( 35, 53, OLED_FONT_SMALL, 0, MOD_LABEL[0]); 
    print_number(modName_idx + 1, find_digits(modName_idx + 1), 60, 53, OLED_FONT_SMALL, 0);
    print( 70, 53, OLED_FONT_SMALL, 0, MOD_DIVIDER[0]); 
    print_number(MAX_MODS_COUNT, find_digits(MAX_MODS_COUNT), 78, 53, OLED_FONT_SMALL, 0);
                                                            
    if(EditVal[ modName_idx ] == 0 ) print( center_x(sizeof(NO_EDIT_VARIABLE)-1, OLED_FONT_SMALL_WIDTH), 40, OLED_FONT_SMALL, 1, NO_EDIT_VARIABLE[0] ); 
    else print( center_x(sizeof(PRESS_A_TO_EDIT)-1, OLED_FONT_SMALL_WIDTH), 40, OLED_FONT_SMALL, 1, PRESS_A_TO_EDIT[0] ); 
        
    if(f_option == 1) { if(f_toggle == 1) print(center_x(sizeof(ON) - 1, OLED_FONT_MEDIUM_WIDTH),SINGLE,OLED_FONT_MEDIUM,OLED_WHITE, ON[0]); else print(center_x(sizeof(OFF) - 1, OLED_FONT_MEDIUM_WIDTH),SINGLE,OLED_FONT_MEDIUM,OLED_WHITE,OFF[0]); }            
    if(f_option == ShotModOptions) { if(f_toggle == 0) print(center_x(sizeof(ModOption_31_0) - 1, OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_31_0[0]); if(f_toggle == 1) print(center_x(sizeof(ModOption_31_1) - 1, OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_31_1[0]); if(f_toggle == 2) print(center_x(sizeof(ModOption_31_2) - 1, OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_31_2[0]); if(f_toggle == 3) print(center_x(sizeof(ModOption_31_3) - 1, OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_31_3[0]); }            
    if(f_option == 50) { if(f_toggle == 0) print(center_x(sizeof(ModOption_50_0) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE,ModOption_50_0[0]); if(f_toggle == 1) print(center_x(sizeof(ModOption_50_1) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE,ModOption_50_1[0]); if(f_toggle == 2) print(center_x(sizeof(ModOption_50_2) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE,ModOption_50_2[0]); if(f_toggle == 3) print(center_x(sizeof(ModOption_50_3) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE,ModOption_50_3[0]); if(f_toggle == 4) print(center_x(sizeof(ModOption_50_4) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE,ModOption_50_4[0]); if(f_toggle == 5) print(center_x(sizeof(ModOption_50_5) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE,ModOption_50_5[0]); }            
    if(f_option == 7) { if(f_toggle == 0) print(center_x(sizeof(ModOption_7_0) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_7_0[0]); if(f_toggle == 1) print(center_x(sizeof(ModOption_7_1) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_7_1[0]); if(f_toggle == 2) print(center_x(sizeof(ModOption_7_2) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_7_2[0]); }
    if(f_option == 55) { if(f_toggle == 0) print(center_x(sizeof(ModOption_55_0) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_55_0[0]); if(f_toggle == 1) print(center_x(sizeof(ModOption_55_1) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_55_1[0]); if(f_toggle == 2) print(center_x(sizeof(ModOption_55_2) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_55_2[0]); if(f_toggle == 3) print(center_x(sizeof(ModOption_55_3) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_55_3[0]); if(f_toggle == 4) print(center_x(sizeof(ModOption_55_4) - 1,OLED_FONT_SMALL_WIDTH),SINGLE,OLED_FONT_SMALL,OLED_WHITE, ModOption_55_4[0]); }
}           

const uint8 MenuButtons [] = { XB1_UP, XB1_DOWN, XB1_LEFT, XB1_RIGHT, XB1_A, XB1_B, XB1_MENU, XB1_LT };
int menu_btn_indx, menu_activity, MenuTimeOut;
define menu_time_active = 30000;
define menu_back_lock_time = 140;

function CheckIfBtnIsPressed (){  
    menu_activity = FALSE;
    for(menu_btn_indx = 0; menu_btn_indx < 8; menu_btn_indx++){ if(event_press(MenuButtons[menu_btn_indx]) ) menu_activity = TRUE; }
    if(menu_activity) MenuTimeOut = menu_time_active; 
    else if(MenuTimeOut > 0) {
        MenuTimeOut -= get_rtime();
        if(MenuTimeOut <= 0 ){ ModMenu = FALSE; ModEdit = FALSE; display_EDIT = FALSE; display_black = FALSE; count_black = 0; gameplay_idle_time = 0; startup_splash_active = FALSE; startup_splash_stage = 0; startup_splash_time = 0; refresh_OLED = FALSE; cls_oled(0); }
    }
}

function display_MOD_status(f_val,f_size,f_label){  
    if(!ModMenu && !ModEdit){                                           
        cls_oled(0); print(f_size, 3, OLED_FONT_MEDIUM ,OLED_WHITE, f_label);   
        if( f_val ) print(center_x(sizeof(ON) - 1, OLED_FONT_LARGE_WIDTH),37,OLED_FONT_LARGE,OLED_WHITE, ON[0]); 
        else print(center_x(sizeof(OFF) - 1, OLED_FONT_LARGE_WIDTH),37,OLED_FONT_LARGE,OLED_WHITE, OFF[0]); 
        time_to_clear_screen = 1500; 
    } 
}

function get_mod_toggle(idx) { if(idx == 0) return EliteRecoil_Active; if(idx == 1) return EliteAA_Active; if(idx == 2) return SniperBreath_Active; if(idx == 3) return CustomSens_Active; if(idx == 4) return Movement_BunnyHop; if(idx == 5) return AutoSpot_Active; if(idx == 6) return AutoReload_Active; if(idx == 7) return HairTrigger_Active; if(idx == 8) return StickDrift_Fix; if(idx == 9) return StickyAim_Active; if(idx == 10) return BlockRumble_Active; if(idx == 11) return AimFireBoost_Active; if(idx == 12) return YY_Movement_Active; if(idx == 13) return VM_Speed_Setting; return 0; }
function set_mod_toggle(idx, val) { if(idx == 0) EliteRecoil_Active = val; if(idx == 1) EliteAA_Active = val; if(idx == 2) SniperBreath_Active = val; if(idx == 3) CustomSens_Active = val; if(idx == 4) Movement_BunnyHop = val; if(idx == 5) AutoSpot_Active = val; if(idx == 6) AutoReload_Active = val; if(idx == 7) HairTrigger_Active = val; if(idx == 8) StickDrift_Fix = val; if(idx == 9) StickyAim_Active = val; if(idx == 10) BlockRumble_Active = val; if(idx == 11) AimFireBoost_Active = val; if(idx == 12) YY_Movement_Active = val; if(idx == 13) VM_Speed_Setting = val; }
function get_pvar_val(idx) { if(idx == 0) return EliteRecoil_V; if(idx == 1) return EliteRecoil_H; if(idx == 2) return AimSize; if(idx == 3) return FireSize; if(idx == 4) return AimAndFireSize; if(idx == 5) return AimSpeed; if(idx == 6) return HipSize; if(idx == 7) return GEN_SENS; if(idx == 8) return ADS_SENS; if(idx == 9) return FIRE_SENS; if(idx == 10) return ADS_FIRE_SENS; if(idx == 11) return GRENADE_SENS; if(idx == 12) return DeadZone; if(idx == 13) return AimFireBoost; if(idx == 14) return EliteTrack_Strength; if(idx == 15) return EliteTrack_Delay; if(idx == 16) return YY_Delay_Timing; return 0; }
function set_pvar_val(idx, val) { if(idx == 0) EliteRecoil_V = val; if(idx == 1) EliteRecoil_H = val; if(idx == 2) AimSize = val; if(idx == 3) FireSize = val; if(idx == 4) AimAndFireSize = val; if(idx == 5) AimSpeed = val; if(idx == 6) HipSize = val; if(idx == 7) GEN_SENS = val; if(idx == 8) ADS_SENS = val; if(idx == 9) FIRE_SENS = val; if(idx == 10) ADS_FIRE_SENS = val; if(idx == 11) GRENADE_SENS = val; if(idx == 12) DeadZone = val; if(idx == 13) AimFireBoost = val; if(idx == 14) EliteTrack_Strength = val; if(idx == 15) EliteTrack_Delay = val; if(idx == 16) YY_Delay_Timing = val; }

